{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "C/C++: g++ build & run active file",
            "command": "g++ -std=c++20 \"${fileBasename}\" -o \"${fileBasenameNoExtension}.exe\" ; if ($?) { & \".\\${fileBasenameNoExtension}.exe\" }",
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "컴파일 후 성공 시 즉시 실행하는 통합 작업입니다."
        }
    ]
}
